{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "gatewayApi": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "gatewayClassName": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": [
              "enabled"
            ]
          },
          "then": {
            "required": [
              "gatewayClassName"
            ]
          }
        }
      ]
    }
  }
}
